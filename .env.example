DATABASE_URL=postgresql://postgres:password@db.example.supabase.co:5432/postgres
SUPABASE_URL=https://example.supabase.co
SUPABASE_JWT_SECRET=
USDA_API_KEY=
OPENROUTER_API_KEY=
# Optional OpenRouter attribution headers:
OPENROUTER_APP_URL=
OPENROUTER_APP_NAME=
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,https://localhost
# Optional regex for local web/mobile development on changing ports:
CORS_ORIGIN_REGEX=^https?://(?:localhost|127\.0\.0\.1|10\.\d{1,3}\.\d{1,3}\.\d{1,3}|172\.(?:1[6-9]|2\d|3[0-1])\.\d{1,3}\.\d{1,3}|192\.168\.\d{1,3}\.\d{1,3})(?::\d+)?$
